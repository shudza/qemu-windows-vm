# ── Hardware ───────────────────────────────────────────────────────
# SMP="cores=4,threads=1,sockets=1"
# MEM="8G"
# HUGEPAGES_COUNT=4096          # MEM in 2MB pages (8G = 4096)
# CPU_PINNING="0-3"             # P-cores; empty string to disable pinning

# ── Paths (auto-detected if unset) ────────────────────────────────
# OVMF_CODE="/usr/share/edk2/x64/OVMF_CODE.4m.fd"
# OVMF_VARS_TEMPLATE="/usr/share/edk2/x64/OVMF_VARS.4m.fd"
# VIRTIOFSD_BIN="/usr/lib/virtiofsd"

# ── Sharing ───────────────────────────────────────────────────────
# SMB_PATH="$HOME/projects"     # shared via QEMU SMB (omit to disable)
# VIRTIOFS_SHARED="./shared"    # shared via virtiofs
# HOST_FORWARDS="hostfwd=tcp::22220-:22,hostfwd=tcp::5000-:5000,hostfwd=tcp::5001-:5001"  # omit to disable

# ── VM ────────────────────────────────────────────────────────────
# DISK_SIZE="100G"
